{
  "entities": {
    "Subscriber": {
      "title": "Subscriber",
      "description": "A user who has subscribed to the newsletter.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user subscribed."
        },
        "source": {
          "type": "string",
          "description": "The source of the subscription (e.g., 'footer', 'popup')."
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Collection of newsletter subscribers."
    }
  }
}
